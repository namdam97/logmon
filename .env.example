# LogMon — biến môi trường local dev. Copy thành .env và điền giá trị thật.
# docker compose tự đọc .env trong infra/docker khi chạy; với `make` ở root,
# export các biến này (hoặc set inline) trước khi chạy target.
# KHÔNG commit .env (đã .gitignore). Production nạp qua secret manager.

# Postgres
POSTGRES_PASSWORD=logmon

# Auth (userservice)
JWT_SECRET=local-dev-insecure-change-me
# Rate limit login/register mỗi IP (make e2e tự set cao để không bị throttle)
AUTH_RATE_PER_MINUTE=10
AUTH_RATE_BURST=5

# Observability (profile observability)
GRAFANA_ADMIN_PASSWORD=admin-change-me
ELASTIC_PASSWORD=local-dev-insecure

# Frontend → backend (FE đọc lúc build; mặc định đã trỏ localhost:8080)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

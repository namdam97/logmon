# LogMon production env — copy sang .env.prod (GITIGNORED, KHÔNG commit) và điền
# giá trị thật. Nạp khi deploy:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod --profile observability up -d
#
# Sinh secret ngẫu nhiên: openssl rand -hex 32

# URL công khai (đứng sau nginx/TLS). Quyết định ALLOWED_ORIGIN + Secure cookie.
PUBLIC_URL=https://logmon.example.com

# Postgres
POSTGRES_PASSWORD=__change_me__

# Auth — PHẢI mạnh (openssl rand -hex 32)
JWT_SECRET=__change_me_64_hex__

# Elasticsearch
ELASTIC_PASSWORD=__change_me__

# Grafana admin
GRAFANA_ADMIN_PASSWORD=__change_me__

# Mã hóa config kênh notification at-rest (AES-256 key, 32 bytes hex)
NOTIFICATION_ENCRYPTION_KEY=__change_me_64_hex__
NOTIFICATION_KEY_ID=v1

# Webhook Alertmanager → userservice (PHẢI khớp secrets/logmon_webhook_token.txt)
ALERTMANAGER_WEBHOOK_TOKEN=__change_me__

# Rate limit auth (prod giữ chặt)
AUTH_RATE_PER_MINUTE=10
AUTH_RATE_BURST=5

# Tracing + log pipeline (prod bật observability profile)
OTEL_EXPORTER_OTLP_ENDPOINT=otel-agent:4317
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_ADDR=redis:6379
